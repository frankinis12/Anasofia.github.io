<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Problema 74 de Sociales</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        :root {
            --color-primary: #ee7752;
            --color-secondary: #e73c7e;
            --color-accent: #23a6d5;
            --color-success: #23d5ab;
            --color-gold: #ffd700;
            --color-pink: #ff6b9d;
            --glass-bg: rgba(255,255,255,0.1);
            --glass-hover: rgba(255,255,255,0.25);
            --shadow-neumorphic: 0 8px 32px rgba(0,0,0,0.3);
            --blur: blur(20px);
        }

        body {
            background: linear-gradient(-45deg, var(--color-primary), var(--color-secondary), var(--color-accent), var(--color-success), var(--color-pink));
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            color: #fff;
            font-family: 'Inter', 'Poppins', -apple-system, sans-serif;
            min-height: 100vh;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 80%, rgba(120,119,198,0.3) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255,119,198,0.3) 0%, transparent 50%),
                radial-gradient(circle at 40% 40%, rgba(120,219,255,0.3) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
            animation: particlesFloat 20s linear infinite;
        }

        @keyframes particlesFloat {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
            50% { transform: translateY(-20px) rotate(180deg); opacity: 0.8; }
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: var(--glass-bg);
            border-radius: 24px;
            padding: 40px;
            box-shadow: var(--shadow-neumorphic), inset 0 1px 0 rgba(255,255,255,0.2);
            backdrop-filter: var(--blur);
            border: 1px solid rgba(255,255,255,0.2);
            animation: slideIn 0.8s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1 {
            text-align: center;
            color: var(--color-gold);
            font-size: clamp(2em, 5vw, 3em);
            margin-bottom: 15px;
            text-shadow: 0 0 20px var(--color-gold);
            font-weight: 700;
            font-family: 'Poppins', sans-serif;
            letter-spacing: -0.02em;
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { text-shadow: 0 0 20px var(--color-gold), 0 0 30px var(--color-gold); }
            to { text-shadow: 0 0 30px var(--color-gold), 0 0 40px var(--color-gold), 0 0 50px var(--color-gold); }
        }

        .subtitle {
            text-align: center;
            color: rgba(255,255,255,0.95);
            font-size: clamp(1.1em, 3vw, 1.3em);
            margin-bottom: 50px;
            font-weight: 400;
            font-family: 'Inter', sans-serif;
        }

        .section {
            margin-bottom: 40px;
            padding: 30px;
            border-radius: 20px;
            background: var(--glass-bg);
            border: 1px solid rgba(255,255,255,0.2);
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            animation: fadeUp 0.6s ease-out forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .section:nth-child(1) { animation-delay: 0.1s; }
        .section:nth-child(2) { animation-delay: 0.2s; }
        .section:nth-child(3) { animation-delay: 0.3s; }

        @keyframes fadeUp {
            to { opacity: 1; transform: translateY(0); }
        }

        .section:hover {
            background: var(--glass-hover);
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.3);
        }

        .section h2 {
            color: var(--color-pink);
            font-size: clamp(1.6em, 4vw, 2em);
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
        }

        .media-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-items: center;
        }


        .card-title {
            font-size: clamp(1.8em, 4.5vw, 2.5em);
            margin-bottom: 25px;
            text-align: center;
            background: linear-gradient(45deg, #fff, var(--color-gold), var(--color-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
        }

        video, audio {
            width: 100%;
            max-height: 500px;
            border-radius: 20px;
            box-shadow: var(--shadow-neumorphic);
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            border: 1px solid rgba(255,255,255,0.2);
        }

        iframe {
            width: 100%;
            height: 600px;
            border-radius: 20px;
            box-shadow: var(--shadow-neumorphic);
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            border: 1px solid rgba(255,255,255,0.2);
        }

        img {
            width: 100%;
            height: 450px;
            object-fit: contain;
            border-radius: 20px;
            box-shadow: var(--shadow-neumorphic);
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            cursor: pointer;
            border: 1px solid rgba(255,255,255,0.2);
        }

        video:hover, audio:hover, iframe:hover, img:hover {
            transform: scale(1.03) rotate(0.5deg);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }

        h3 {
            color: var(--color-gold);
            font-size: clamp(1.2em, 3vw, 1.5em);
            text-align: center;
            margin-bottom: 15px;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
        }

        .instruction {
            background: var(--glass-bg);
            padding: 20px;
            border-radius: 16px;
            font-style: italic;
            opacity: 0.9;
            text-align: center;
            backdrop-filter: var(--blur);
            border: 1px solid rgba(255,255,255,0.2);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
        }

        .question {
            background: var(--glass-hover);
            padding: 30px;
            border-radius: 20px;
            margin-bottom: 30px;
            font-size: clamp(1em, 2.5vw, 1.2em);
            line-height: 1.8;
            backdrop-filter: var(--blur);
            border: 1px solid rgba(255,255,255,0.15);
            font-family: 'Inter', sans-serif;
        }

        .options {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .option {
            padding: 25px;
            background: var(--glass-bg);
            border: 2px solid transparent;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            font-size: clamp(1em, 2.5vw, 1.15em);
            text-align: center;
            backdrop-filter: var(--blur);
            position: relative;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .option::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255,255,255,0.3);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .option:active::before {
            width: 300px;
            height: 300px;
        }

        .option:hover {
            background: var(--glass-hover);
            border-color: var(--color-gold);
            transform: translateY(-8px) scale(1.02);
            box-shadow: var(--shadow-neumorphic);
        }

        .option.correct {
            border-color: var(--color-success);
            background: rgba(35,213,171,0.4);
            box-shadow: 0 0 20px rgba(35,213,171,0.5);
        }

        .option.incorrect {
            border-color: #ff4757;
            background: rgba(255,71,87,0.4);
            box-shadow: 0 0 20px rgba(255,71,87,0.3);
        }

        .buttons {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
        }

        button {
            background: linear-gradient(45deg, var(--color-pink), var(--color-gold));
            color: #fff;
            border: none;
            padding: 18px 40px;
            font-size: clamp(1.1em, 2.5vw, 1.25em);
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            font-weight: 600;
            box-shadow: 0 12px 30px rgba(255,107,157,0.5);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-family: 'Poppins', sans-serif;
            position: relative;
            overflow: hidden;
        }

        button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s;
        }

        button:hover::before {
            left: 100%;
        }

        button:hover {
            transform: translateY(-6px) scale(1.05);
            box-shadow: 0 20px 40px rgba(255,107,157,0.7);
        }

        .feedback {
            font-size: clamp(1.3em, 3vw, 1.6em);
            font-weight: 700;
            text-align: center;
            padding: 25px;
            min-height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 20px;
            margin-top: 25px;
            backdrop-filter: var(--blur);
            animation: bounceIn 0.6s ease-out;
            font-family: 'Poppins', sans-serif;
        }

        @keyframes bounceIn {
            0% { transform: scale(0.8); opacity: 0; }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); opacity: 1; }
        }

        .success { 
            background: rgba(35,213,171,0.4);
            color: var(--color-success); 
            box-shadow: 0 0 30px rgba(35,213,171,0.6);
            border: 1px solid var(--color-success);
        }
        .error { 
            background: rgba(255,71,87,0.4);
            color: #ff4757; 
            box-shadow: 0 0 30px rgba(255,71,87,0.4);
            border: 1px solid #ff4757;
        }

        @media (max-width: 1024px) {
            .main-grid {
                grid-template-columns: 1fr;
                grid-template-rows: auto auto auto auto;
                height: auto;
            }
            
            .media-card, .files-card {
                grid-column: 1;
                grid-row: auto;
            }

            video, audio { max-height: 400px; }
        }

        @media (max-width: 768px) {
            .options {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            
            .buttons {
                flex-direction: column;
                gap: 15px;
            }

            h1 {
                font-size: clamp(1.8em, 8vw, 2.5em);
            }

            body {
                padding: 10px;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 20px;
                border-radius: 16px;
            }

            iframe {
                height: 400px;
            }
        }
    </style>
</head>

<body>
    <div class="main-grid">
        <div class="header">
            <h1>🎉 Problema 74 de Sociales</h1>
            <p class="subtitle"></p>
        </div>

        <div class="media-card">
            <h2 class="card-title">🎥 Video &amp; 🎵 Audio</h2>
            <video controls>
                <source src="Matrimonio_Igualitario_Col_.mp4" type="video/mp4">
                
            </video>
            <p class="instruction"></p>
            
            <audio controls>
                <source src="Audio2.mp3" type="audio/mpeg">
                
            </audio>
            <p class="instruction"></p>
        </div>

        <div class="files-card">
            <h2 class="card-title"></h2>
            
            <h3>📕 Presentación</h3>
            <iframe src="Colombia_Family_Law_Evolution.pdf" style="height: 600px;">
                <a href="Colombia_Family_Law_Evolution.pdf"></a>
            </iframe>
            
            <h3>🖼️ Infografía</h3>
            <img src="unnamed.png" alt="Imagen 1" onclick="openFull(this.src)">
            
            <h3>🖼️ Mapa Mental</h3>
            <img src="NotebookLM Mind Map.png" alt="Imagen 2" onclick="openFull(this.src)">
            
            

        <div class="quiz-card">
            <h2 class="card-title">❓ Pregunta</h2>
            <div class="question">
                <p> 74. En el 2011, la Corte Constitucional de Colombia estableció que las parejas conformadas por personas del mismo sexo sí constituyen una familia. Cinco años después, la misma entidad reconoció la validez del matrimonio igualitario para estas mismas parejas. Antes de eso, solo las parejas heterosexuales podían casarse legalmente, mientras que las homosexuales solo podían acceder a una figura contractual llamada “unión solemne”, la cual otorgaba solo algunos de los derechos conferidos a los matrimonios. Con esto, la Corte Constitucional busca responder a los nuevos patrones en la conformación de las familias en el país y evitar que los derechos de cerca de cuatro millones de colombianos sigan siendo vulnerados. <br>

                    Con base en la información anterior, ¿cuál de las siguientes afirmaciones es una de las razones por las cuales se modificó el concepto legal de matrimonio y familia en Colombia?
                </p>
            </div>
            <div class="options">
                <div class="option" onclick="selectOption(this, 'A')">A) Para restringir los derechos de las familias católicas, ya que, al considerar todos los matrimonios como iguales, se reduce la dimensión sagrada del matrimonio.</div>
                <div class="option" onclick="selectOption(this, 'B')">B) Para privilegiar los derechos de los homosexuales, ya que estas personas ahora recibirán un trato preferencial por su orientación sexual.</div>
                <div class="option" onclick="selectOption(this, 'C')">C) Para facilitar la convivencia en una sociedad cambiante, ya que las normas deben adaptarse a las transformaciones sociales</div>
                <div class="option" onclick="selectOption(this, 'D')">D) Para priorizar los valores de la sociedad, ya que estos son el centro de la vida en comunidad y no deberían modificarse</div>
            </div>
            <div class="buttons">
                <button onclick="checkAnswer()">Verificar</button>
                <button onclick="resetQuiz()">Nuevo</button>
            </div>
            <div id="feedback" class="feedback"></div>
        </div>
    </div>

    <script>
        let selectedAnswer = null;

        function openFull(src) {
            window.open(src, '_blank');
        }

        function selectOption(element, answer) {
            document.querySelectorAll('.option').forEach(opt => {
                opt.style.borderColor = 'transparent';
                opt.style.background = 'rgba(255,255,255,0.2)';
            });
            element.style.borderColor = '#ffd700';
            element.style.background = 'rgba(255,255,255,0.4)';
            selectedAnswer = answer;
        }

        function checkAnswer() {
            const feedback = document.getElementById('feedback');
            if (!selectedAnswer) {
                feedback.innerHTML = '⚠️ Selecciona una opción primero';
                feedback.className = 'feedback error';
                return;
            }

            const correctAnswer = 'C'; // Cambiar según necesites
            if (selectedAnswer === correctAnswer) {
                feedback.innerHTML = '🎉 ¡Excelente! Respuesta correcta';
                feedback.className = 'feedback success';
                document.querySelector('.option:nth-child(3)').classList.add('correct');
            } else {
                feedback.innerHTML = '❌ Incorrecto. Inténtalo de nuevo';
                feedback.className = 'feedback error';
                document.querySelector('.option:nth-child(3)').classList.add('correct');
                document.querySelector(`[onclick="selectOption(this, '${selectedAnswer}')"]`).classList.add('incorrect');
            }
        }

        function resetQuiz() {
            selectedAnswer = null;
            document.getElementById('feedback').innerHTML = '';
            document.getElementById('feedback').className = 'feedback';
            document.querySelectorAll('.option').forEach(opt => {
                opt.classList.remove('correct', 'incorrect');
                opt.style.borderColor = 'transparent';
                opt.style.background = 'rgba(255,255,255,0.2)';
            });
        }
    </script>
</body>
</html>
